[
  { "title": "Eisen No. 761", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://dive3d.eu/wp-content/uploads/Clipboard02-7.jpg", "subtitle": "A haunting site for aviation enthusiasts, the Eisen No. 761 is a Mitsubishi G4M Betty bomber resting in the shallow waters of Chuuk Lagoon. Unlike the massive ships nearby, this twin-engine bomber offers a rare, intimate look at WWII aerial history. Divers can inspect the cockpit, engines, and the iconic cigar-shaped fuselage, which remains remarkably intact. Encircled by schools of tropical fish and delicate coral growth, the Betty bomber is a poignant reminder of the fierce air battles that once raged above these now-serene waters.", "lat": 7.374564, "lng": 151.8571829, "isFixed": true },
  { "title": "Futagami Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://dive3d.eu/wp-content/uploads/Clipboard02-7.jpg", "subtitle": "The Futagami, a Japanese naval tugboat, offers one of the most accessible and photogenic dives in Chuuk Lagoon. Resting on its starboard side at a shallow depth, the wreck is draped in a kaleidoscope of soft corals and sea fans that thrive in the gentle current. Its beautifully preserved propeller and engine room provide a hauntingly scenic backdrop for underwater photographers. Whether you're navigating its bridge or marveling at the vibrant marine life reclaiming the steel, the Futagami is a captivating testament to the lagoon's silent history.", "lat": 7.3719388, "lng": 151.856456, "isFixed": true },
  { "title": "Gosei Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://dive3d.eu/wp-content/uploads/Gosei-1038x576.jpg", "subtitle": "Resting on a steep incline, the Gosei Maru is a coastal freighter famous for its massive, shallow propeller. Often called the 'Diamond Ship' due to the markings on its funnel, it offers divers a chance to see torpedoes in the holds and beautiful coral growth across the stern.", "lat": 7.3112, "lng": 151.8874, "isFixed": true },
  { "title": "Heian Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://upload.wikimedia.org/wikipedia/commons/8/85/Heian_Maru.jpg", "subtitle": "At 155m long, the Heian Maru is the largest wreck in the lagoon. Originally a luxury liner turned submarine tender, it rests on its side. Divers can still see periscopes, torpedoes, and medical supplies scattered throughout its massive interior.", "lat": 7.3855, "lng": 151.854639, "isFixed": true },
  { "title": "Hokuyo Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://lh3.googleusercontent.com/pw/AP1GczP2WBNMy_wIPlGARZkROTEj8iPutKEdq6qVVlw2NP8fMi4WilJ1jAsduKqiSU_lRivvsuq7y_cnIxR5CiG36xFuRRGYzkKPcjqcsEfJSRNX2CaKEDMgHwcIsImH8WzKkUUfdOAvN8ludoiDBUL4x9_3IQ=w817-h521-s-no-gm?authuser=0", "subtitle": "A massive merchant vessel that met its end during the relentless strikes of Operation Hailstone. Resting deep on the lagoon floor, the Hokuyo Maru is renowned for its cavernous engine room and the eerie beauty of its silt-covered decks, now reclaimed by vibrant Pacific marine life.", "lat": 7.36055, "lng": 151.90999146, "isFixed": true },
  { "title": "I-169 Submarine", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://dive3d.eu/wp-content/uploads/I-171-1038x449.jpg", "subtitle": "The only submarine wreck accessible in the lagoon, the I-169 Shinohara met a tragic end when it submerged to avoid an air raid and failed to resurface. It now serves as a somber war grave resting on the seabed.", "lat": 7.38867, "lng": 151.8322, "isFixed: true },
  { "title": "Kikukawa Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://lh3.googleusercontent.com/pw/AP1GczP2WBNMy_wIPlGARZkROTEj8iPutKEdq6qVVlw2NP8fMi4WilJ1jAsduKqiSU_lRivvsuq7y_cnIxR5CiG36xFuRRGYzkKPcjqcsEfJSRNX2CaKEDMgHwcIsImH8WzKkUUfdOAvN8ludoiDBUL4x9_3IQ=w817-h521-s-no-gm?authuser=0", "subtitle": "A relatively shallow wreck, the Kikukawa Maru was a cargo ship carrying fuel drums when it was caught in the air raids. Today, it offers a fascinating dive through its open holds and bridge area, surrounded by a variety of tropical fish and delicate coral formations.", "lat": 7.356718, "lng": 151.915079, "isFixed": true },
  { "title": "Matsutan Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://lh3.googleusercontent.com/pw/AP1GczP2WBNMy_wIPlGARZkROTEj8iPutKEdq6qVVlw2NP8fMi4WilJ1jAsduKqiSU_lRivvsuq7y_cnIxR5CiG36xFuRRGYzkKPcjqcsEfJSRNX2CaKEDMgHwcIsImH8WzKkUUfdOAvN8ludoiDBUL4x9_3IQ=w817-h521-s-no-gm?authuser=0", "subtitle": "A massive freighter that met its end during Operation Hailstone, the Momokawa Maru is a favorite for wreck enthusiasts. Resting upright, it features holds filled with aircraft parts, truck frames, and artillery shells, while its expansive bridge provides a hauntingly clear view of its final moments.", "lat": 7.3627507, "lng": 151.9219841, "isFixed": true },
  { "title": "Momokawa Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://lh3.googleusercontent.com/pw/AP1GczP2WBNMy_wIPlGARZkROTEj8iPutKEdq6qVVlw2NP8fMi4WilJ1jAsduKqiSU_lRivvsuq7y_cnIxR5CiG36xFuRRGYzkKPcjqcsEfJSRNX2CaKEDMgHwcIsImH8WzKkUUfdOAvN8ludoiDBUL4x9_3IQ=w817-h521-s-no-gm?authuser=0", "subtitle": "A massive freighter that met its end during Operation Hailstone, the Momokawa Maru is a favorite for wreck enthusiasts. Resting upright, it features holds filled with aircraft parts, truck frames, and artillery shells, while its expansive bridge provides a hauntingly clear view of its final moments.", "lat": 7.367016, "lng": 151.9147158, "isFixed": true },
  { "title": "Nagano Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://lh3.googleusercontent.com/pw/AP1GczP2WBNMy_wIPlGARZkROTEj8iPutKEdq6qVVlw2NP8fMi4WilJ1jAsduKqiSU_lRivvsuq7y_cnIxR5CiG36xFuRRGYzkKPcjqcsEfJSRNX2CaKEDMgHwcIsImH8WzKkUUfdOAvN8ludoiDBUL4x9_3IQ=w817-h521-s-no-gm?authuser=0", "subtitle": "Resting upright on the lagoon floor, the Nagano Maru is a remarkably intact freighter that offers divers a haunting look at WWII history. Known for its well-preserved bridge and cavernous holds still containing trucks and supplies, it stands as a silent monument to the Pacific conflict.", "lat": 7.366032, "lng": 151.9194402, "isFixed": true },
  { "title": "Nippo Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://upload.wikimedia.org/wikipedia/commons/thumb/0/07/Nippo_Maru_Bridge.jpg/800px-Nippo_Maru_Bridge.jpg", "subtitle": "The Nippo Maru offers a diverse collection of relics, including a battle tank on deck and several trucks. The bridge remains in remarkably good condition, with the ship's wheel and telegraph still standing as silent sentinels of the Pacific theater.", "lat": 7.382439, "lng": 151.920167, "isFixed": true },
  { "title": "Ojima", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://lh3.googleusercontent.com/pw/AP1GczP2WBNMy_wIPlGARZkROTEj8iPutKEdq6qVVlw2NP8fMi4WilJ1jAsduKqiSU_lRivvsuq7y_cnIxR5CiG36xFuRRGYzkKPcjqcsEfJSRNX2CaKEDMgHwcIsImH8WzKkUUfdOAvN8ludoiDBUL4x9_3IQ=w817-h521-s-no-gm?authuser=0", "subtitle": "A small tugboat or work vessel resting in the shallow waters of Chuuk Lagoon, the Ojima is a hidden gem for macro photographers. Its hull is beautifully draped in soft corals and sponges, providing a vibrant home for nudibranchs and small reef fish in a peaceful setting.", "lat": 7.358687, "lng": 151.9161695, "isFixed": true },
  { "title": "Patrol Boat No 34", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://www.combinedfleet.com/Fujisan.jpg", "subtitle": "Originally an Imperial Japanese Navy destroyer, the Patrol Boat No. 34 (formerly the Suzuki) now rests as a fascinating shallow-water wreck in Chuuk Lagoon. Resting on its starboard side, this site is a playground for divers, featuring a beautifully preserved 4.7-inch bow gun and depth charge throwers. Its proximity to the surface allows natural light to dance across the coral-encrusted hull, making it a dream for underwater photographers seeking to capture the silhouette of a vessel that once patrolled the front lines of the Pacific.", "lat": 7.366032, "lng": 151.8571829, "isFixed": true },
  { "title": "Reiyo Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://lh3.googleusercontent.com/pw/AP1GczP2WBNMy_wIPlGARZkROTEj8iPutKEdq6qVVlw2NP8fMi4WilJ1jAsduKqiSU_lRivvsuq7y_cnIxR5CiG36xFuRRGYzkKPcjqcsEfJSRNX2CaKEDMgHwcIsImH8WzKkUUfdOAvN8ludoiDBUL4x9_3IQ=w817-h521-s-no-gm?authuser=0", "subtitle": "Resting on her port side, the Reiyo Maru is a freighter that offers a surreal diving experience. Famous for its beautifully preserved bridge and expansive holds, the wreck is now a thriving artificial reef where history and marine life collide in the deep blue.", "lat": 7.368975, "lng": 151.923801, "isFixed": true },
  { "title": "Seiko Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://dive3d.eu/wp-content/uploads/Seiko-Gemini-sw-1038x576.jpg", "subtitle": "A massive cargo ship resting upright, the Seiko Maru is famous for the stunning coral growth on its mast and the torpedo hole in its hull. Divers can explore the well-preserved engine room and the galley, which still contains various cooking utensils from its final voyage.", "lat": 7.36111, "lng": 151.90563, "isFixed": true },
  { "title": "Shinkoku Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/a1/Shinkoku_Maru.jpg/800px-Shinkoku_Maru.jpg", "subtitle": "A massive oil tanker transformed into a vibrant artificial reef. Known for its incredible coral growth and marine life, the wreck features a perfectly preserved engine room and a surgical table in the sick bay, making it a favorite for underwater photographers.", "lat": 7.3825, "lng": 151.8016, "isFixed": true },
  { "title": "Yamagiri Maru", "location": "Chuuk, Federated States of Micronesia", "attimage": "https://upload.wikimedia.org/wikipedia/commons/thumb/8/8e/Yamagiri_Maru_Skull.jpg/800px-Yamagiri_Maru_Skull.jpg", "subtitle": "This transport ship is notorious for the 'human skull' fused into the bulkhead of the engine room. It was carrying massive 14-inch shells for the battleships Yamato and Musashi, which can still be seen stacked in its cavernous holds.", "lat": 7.3903, "lng": 151.8203, "isFixed": true }
